{
  "name": "jarvis-neural-command-interface",
  "version": "0.9.0",
  "private": false,
  "type": "module",
  "main": "electron/main.cjs",
  "description": "A local desktop neural command interface (Windows + macOS) for chat, memory, and Codex-powered tasks.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jonathangana131-lab/jarvis-neural-command-interface.git"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:client": "vite --host 127.0.0.1",
    "dev:server": "node --env-file-if-exists=.env --experimental-sqlite server/index.mjs",
    "desktop": "node scripts/desktop.mjs",
    "desktop:smoke": "node scripts/desktop.mjs --smoke",
    "build": "tsc && vite build",
    "test:memory": "node --experimental-sqlite scripts/test-memory.mjs",
    "test:voice-settings": "node --experimental-sqlite scripts/test-voice-settings.mjs",
    "test:artifacts": "node --experimental-sqlite scripts/test-streaming-artifacts.mjs",
    "test:stream-parser": "node --experimental-sqlite scripts/test-stream-parser.mjs",
    "test:provider-failures": "node --experimental-sqlite scripts/test-provider-failures.mjs",
    "test:reliability-controls": "node --experimental-sqlite scripts/test-reliability-controls.mjs",
    "test:live-smoke": "node --experimental-sqlite scripts/test-live-stream-smoke.mjs",
    "test:packaged-smoke": "node --experimental-sqlite scripts/test-packaged-app-smoke.mjs",
    "test:installed-ui-smoke": "node --experimental-sqlite scripts/test-installed-ui-smoke.mjs",
    "preview": "node --experimental-sqlite server/index.mjs",
    "package:win": "npm run build && electron-builder --win --dir",
    "package:win:dir": "npm run build && electron-builder --win --dir --publish never",
    "prepare:mac-icon": "node scripts/prepare-mac-icon.mjs",
    "package:mac": "npm run prepare:mac-icon && npm run build && electron-builder --mac --dir --publish never",
    "dist:mac": "npm run prepare:mac-icon && npm run build && electron-builder --mac --publish never",
    "installer:win": "npm run build && electron-builder --win nsis",
    "installer:win:from-dir": "electron-builder --win nsis --prepackaged release/win-unpacked --publish never",
    "installer:win:quick": "electron-builder --win nsis --prepackaged release/win-unpacked --publish never --config.compression=store",
    "dist:win": "npm run installer:win",
    "dist:win:fast": "npm run package:win:dir && npm run installer:win:from-dir",
    "install:local:from-dir": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-local-fast.ps1",
    "install:local:fast": "npm run package:win:dir && npm run install:local:from-dir"
  },
  "build": {
    "appId": "local.jarvis.neural-command-interface",
    "productName": "Jarvis Neural Command Interface",
    "executableName": "Jarvis Neural Command Interface",
    "asar": false,
    "compression": "store",
    "directories": {
      "output": "release"
    },
    "afterPack": "scripts/after-pack.cjs",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server/**/*",
      "build/**/*",
      "jarvis.config.json",
      "package.json",
      "!node_modules/onnxruntime-web/**/*"
    ],
    "publish": null,
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        "dir",
        "nsis"
      ],
      "files": [
        "!node_modules/onnxruntime-node/bin/napi-v6/darwin/**/*",
        "!node_modules/onnxruntime-node/bin/napi-v6/linux/**/*",
        "!node_modules/onnxruntime-node/bin/napi-v6/win32/arm64/**/*"
      ]
    },
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "artifactName": "Jarvis-Neural-Command-Interface-${version}-${arch}.${ext}",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ],
      "files": [
        "!node_modules/onnxruntime-node/bin/napi-v6/win32/**/*",
        "!node_modules/onnxruntime-node/bin/napi-v6/linux/**/*"
      ],
      "publish": {
        "provider": "github",
        "owner": "jonathangana131-lab",
        "repo": "jarvis-neural-command-interface",
        "releaseType": "release"
      }
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Jarvis Neural Command Interface",
      "uninstallDisplayName": "Jarvis Neural Command Interface",
      "include": "build/installer.nsh",
      "artifactName": "Jarvis-Neural-Command-Interface-Setup-${version}.${ext}"
    },
    "dmg": {
      "title": "Jarvis Neural Command Interface ${version}"
    }
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@shoelace-style/shoelace": "^2.20.1",
    "electron-updater": "^6.8.3",
    "express": "^5.1.0",
    "gsap": "^3.15.0",
    "lucide": "^1.14.0",
    "three": "^0.176.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.10.1",
    "@types/three": "^0.184.0",
    "@types/ws": "^8.18.1",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.2"
  }
}
